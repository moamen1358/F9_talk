# Copy to ~/.config/F9_talk/secrets.env (chmod 600) and fill in.
# Or place at ./.env in the project root for local dev.

# Required for cloud backend. Sign up free at https://console.deepgram.com/signup
DEEPGRAM_API_KEY=

# Optional alternative cloud backend. Sign up at https://app.gladia.io
GLADIA_API_KEY=

# Optional: bumps MyMemory translation fallback from 5K → 50K chars/day.
# Any email works (it's just a rate-limit bucket key).
MYMEMORY_EMAIL=
